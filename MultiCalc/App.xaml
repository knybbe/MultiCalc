<Application x:Class="MultiCalc.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
      </ResourceDictionary.MergedDictionaries>

      <!-- Calculator button styles for compact, nice look -->
      <Style x:Key="CalcButton" TargetType="Button">
          <Setter Property="Width" Value="62" />
          <Setter Property="Height" Value="62" />
          <Setter Property="FontSize" Value="22" />
          <Setter Property="Margin" Value="1" />
          <Setter Property="Padding" Value="0" />
          <Setter Property="HorizontalContentAlignment" Value="Center" />
          <Setter Property="VerticalContentAlignment" Value="Center" />
      </Style>

      <Style x:Key="OperatorButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
          <Setter Property="Background" Value="#FF9500" />
          <Setter Property="Foreground" Value="White" />
          <Setter Property="FontSize" Value="24" />
      </Style>

      <Style x:Key="EqualsButton" TargetType="Button" BasedOn="{StaticResource OperatorButton}">
          <Setter Property="Background" Value="#34C759" />
          <Setter Property="FontWeight" Value="Bold" />
      </Style>

      <Style x:Key="ClearButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
          <Setter Property="Background" Value="#A2A2A2" />
      </Style>

    </ResourceDictionary>
  </Application.Resources>

</Application>
