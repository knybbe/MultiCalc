<Page x:Class="MultiCalc.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:MultiCalc"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Width="280"
          Padding="6"
          RowSpacing="2"
          ColumnSpacing="2"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
          ColumnDefinitions="*,*,*,*">

        <!-- Display area with calculator look -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="4"
                Background="#1C1C1E"
                CornerRadius="6"
                Padding="8,6"
                Margin="0,0,0,4">
            <StackPanel>
                <!-- Secondary / operation display -->
                <TextBlock x:Name="OperationDisplay"
                           Text=""
                           FontSize="14"
                           HorizontalAlignment="Right"
                           Foreground="#8E8E93" />

                <!-- Main result display -->
                <TextBlock x:Name="ResultDisplay"
                           Text="0"
                           FontSize="36"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Right"
                           Foreground="White"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <!-- Row 2: C, +/-, %, / -->
        <Button Content="C"     Grid.Row="2" Grid.Column="0" Click="OnClear" Style="{StaticResource ClearButton}" />
        <Button Content="+/-"   Grid.Row="2" Grid.Column="1" Click="OnNegate" Style="{StaticResource CalcButton}" />
        <Button Content="%"     Grid.Row="2" Grid.Column="2" Click="OnPercent" Style="{StaticResource CalcButton}" />
        <Button Content="÷"     Grid.Row="2" Grid.Column="3" Click="OnOperator" Style="{StaticResource OperatorButton}" />

        <!-- Row 3 -->
        <Button Content="7" Grid.Row="3" Grid.Column="0" Click="OnNumber" Style="{StaticResource CalcButton}" />
        <Button Content="8" Grid.Row="3" Grid.Column="1" Click="OnNumber" Style="{StaticResource CalcButton}" />
        <Button Content="9" Grid.Row="3" Grid.Column="2" Click="OnNumber" Style="{StaticResource CalcButton}" />
        <Button Content="×" Grid.Row="3" Grid.Column="3" Click="OnOperator" Style="{StaticResource OperatorButton}" />

        <!-- Row 4 -->
        <Button Content="4" Grid.Row="4" Grid.Column="0" Click="OnNumber" Style="{StaticResource CalcButton}" />
        <Button Content="5" Grid.Row="4" Grid.Column="1" Click="OnNumber" Style="{StaticResource CalcButton}" />
        <Button Content="6" Grid.Row="4" Grid.Column="2" Click="OnNumber" Style="{StaticResource CalcButton}" />
        <Button Content="−" Grid.Row="4" Grid.Column="3" Click="OnOperator" Style="{StaticResource OperatorButton}" />

        <!-- Row 5 -->
        <Button Content="1" Grid.Row="5" Grid.Column="0" Click="OnNumber" Style="{StaticResource CalcButton}" />
        <Button Content="2" Grid.Row="5" Grid.Column="1" Click="OnNumber" Style="{StaticResource CalcButton}" />
        <Button Content="3" Grid.Row="5" Grid.Column="2" Click="OnNumber" Style="{StaticResource CalcButton}" />
        <Button Content="+" Grid.Row="5" Grid.Column="3" Click="OnOperator" Style="{StaticResource OperatorButton}" />

        <!-- Row 6 -->
        <Button Content="←" Grid.Row="6" Grid.Column="0" Click="OnBackspace" Style="{StaticResource CalcButton}" />
        <Button Content="0" Grid.Row="6" Grid.Column="1" Click="OnNumber" Style="{StaticResource CalcButton}" />
        <Button Content="." Grid.Row="6" Grid.Column="2" Click="OnDecimal" Style="{StaticResource CalcButton}" />
        <Button Content="=" Grid.Row="6" Grid.Column="3" Click="OnEquals" Style="{StaticResource EqualsButton}" />

    </Grid>
</Page>
